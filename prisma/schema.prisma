generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserRole {
  ADMIN
  USER
}

enum PlanType {
  FREE
  PRO
  ENTERPRISE
}

enum PhysicsMathTaskType {
  VECTOR
  MATRIX
  ODE
  PDE
  NUMERICAL
}

enum PhysicsMathTaskStatus {
  PENDING
  COMPLETED
  FAILED
}

enum PredictionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id       String   @id @default(uuid())
  name     String
  email    String   @unique
  password String
  role     UserRole @default(USER)

  plan       PlanType @default(FREE)
  dailyLimit Int      @default(5)
  isActive   Boolean  @default(true)

  refreshToken String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedules   Schedule[]
  analytics   AnalyticsEvent[]
  mathTasks   PhysicsMathTask[]
  predictions Prediction[]
  usageLogs   UsageLog[]
}

//////////////////////////////////////////////////////
// SCHEDULE
//////////////////////////////////////////////////////

model Schedule {
  id          String   @id @default(uuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// ANALYTICS
//////////////////////////////////////////////////////

model AnalyticsEvent {
  id       String @id @default(uuid())
  event    String
  metadata Json?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

//////////////////////////////////////////////////////
// PHYSICS / MATH TASK
//////////////////////////////////////////////////////

model PhysicsMathTask {
  id         String                @id @default(uuid())
  taskType   PhysicsMathTaskType
  inputData  Json
  resultData Json?
  status     PhysicsMathTaskStatus @default(PENDING)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

//////////////////////////////////////////////////////
// PREDICTION
//////////////////////////////////////////////////////

model Prediction {
  id String @id @default(uuid())

  platform    String
  contentType String
  topic       String
  region      String?

  status PredictionStatus @default(PENDING)

  tokensUsed       Int     @default(0)
  processingTimeMs Int?
  failureReason    String?
  modelVersion     String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  result PredictionResult?

  createdAt   DateTime   @default(now())
  completedAt DateTime?
  usageLogs   UsageLog[]

  @@index([userId])
  @@index([status])
}

//////////////////////////////////////////////////////
// PREDICTION RESULT
//////////////////////////////////////////////////////

model PredictionResult {
  id String @id @default(uuid())

  hashtags    Json?
  scripts     Json?
  explanation Json?

  predictionId String     @unique
  prediction   Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// USAGE LOG
//////////////////////////////////////////////////////

model UsageLog {
  id String @id @default(uuid())

  tokensUsed   Int
  costEstimate Float?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  predictionId String?
  prediction   Prediction? @relation(fields: [predictionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
