// Trendomic - PostgreSQL schema via Prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum PhysicsMathTaskType {
  VECTOR
  MATRIX
  ODE
  PDE
  NUMERICAL
}

enum PhysicsMathTaskStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  role         UserRole @default(USER)
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roleId           String?
  roleRel          Role?             @relation(fields: [roleId], references: [id])
  schedules        Schedule[]
  analytics        AnalyticsEvent[]
  physicsMathTasks PhysicsMathTask[]
}

model Role {
  id          String @id @default(uuid())
  name        String @unique
  permissions Json // e.g. ["users:read", "schedules:write"]
  users       User[]
}

model Schedule {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  userId    String
  event     String
  metadata  Json? // flexible event payload
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([event])
  @@index([createdAt])
}

model PhysicsMathTask {
  id         String                @id @default(uuid())
  userId     String
  taskType   PhysicsMathTaskType
  inputData  Json
  resultData Json?
  status     PhysicsMathTaskStatus @default(PENDING)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([taskType])
}
